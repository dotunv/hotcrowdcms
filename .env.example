# HotCrowd CMS Environment Variables

# PostgreSQL Database Configuration
DB_NAME=hotcrowdcms
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432

# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True

# File Storage Configuration
# Set to True to use Cloudflare R2 (production), False for local storage (development)
USE_S3=False

# Cloudflare R2 Configuration (Only needed when USE_S3=True)
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_bucket_name
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_CUSTOM_DOMAIN=media.yourdomain.com

# Instagram Integration (Optional)
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password
